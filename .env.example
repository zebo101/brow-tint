# app
NEXT_PUBLIC_APP_URL = "http://localhost:3000"
NEXT_PUBLIC_APP_NAME = "Brow Tint"
# OG / Twitter Card image; recommend a designed 1200x630 PNG/JPG.
# NEXT_PUBLIC_APP_PREVIEW_IMAGE = "/imgs/features/landingpage.jpg"

# theme
NEXT_PUBLIC_THEME = "default"

# appearance
NEXT_PUBLIC_APPEARANCE = "system"

# HeroUI Pro install key, required during Nixpacks dependency install.
HEROUI_KEY = ""

# database
DATABASE_PROVIDER = "turso"
DATABASE_URL = ""
DB_SINGLETON_ENABLED = "true"
DB_MAX_CONNECTIONS = "1"

# auth secret
# openssl rand -base64 32
AUTH_SECRET = ""
